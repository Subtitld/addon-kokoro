    {"id": "kokoro-af-nova",     "language": "en-us", "display_name": "Nova — American female"},
    {"id": "kokoro-af-river",    "language": "en-us", "display_name": "River — American female"},
    {"id": "kokoro-af-sarah",    "language": "en-us", "display_name": "Sarah — American female"},
    {"id": "kokoro-af-sky",      "language": "en-us", "display_name": "Sky — American female"},
    {"id": "kokoro-am-adam",     "language": "en-us", "display_name": "Adam — American male"},
    {"id": "kokoro-am-echo",     "language": "en-us", "display_name": "Echo — American male"},
    {"id": "kokoro-am-eric",     "language": "en-us", "display_name": "Eric — American male"},
    {"id": "kokoro-am-fenrir",   "language": "en-us", "display_name": "Fenrir — American male"},
    {"id": "kokoro-am-liam",     "language": "en-us", "display_name": "Liam — American male"},
    {"id": "kokoro-am-michael",  "language": "en-us", "display_name": "Michael — American male"},
    {"id": "kokoro-am-onyx",     "language": "en-us", "display_name": "Onyx — American male"},
    {"id": "kokoro-am-puck",     "language": "en-us", "display_name": "Puck — American male"},
    {"id": "kokoro-am-santa",    "language": "en-us", "display_name": "Santa — American male"},
    {"id": "kokoro-bf-alice",    "language": "en-gb", "display_name": "Alice — British female"},
    {"id": "kokoro-bf-emma",     "language": "en-gb", "display_name": "Emma — British female"},
    {"id": "kokoro-bf-isabella", "language": "en-gb", "display_name": "Isabella — British female"},
    {"id": "kokoro-bf-lily",     "language": "en-gb", "display_name": "Lily — British female"},
    {"id": "kokoro-bm-daniel",   "language": "en-gb", "display_name": "Daniel — British male"},
    {"id": "kokoro-bm-fable",    "language": "en-gb", "display_name": "Fable — British male"},
    {"id": "kokoro-bm-george",   "language": "en-gb", "display_name": "George — British male"},
    {"id": "kokoro-bm-lewis",    "language": "en-gb", "display_name": "Lewis — British male"},
    {"id": "kokoro-jf-alpha",    "language": "ja",    "display_name": "Alpha — Japanese female"},
    {"id": "kokoro-jf-gongitsune","language": "ja",   "display_name": "Gongitsune — Japanese female"},
    {"id": "kokoro-jf-nezumi",   "language": "ja",    "display_name": "Nezumi — Japanese female"},
    {"id": "kokoro-jf-tebukuro", "language": "ja",    "display_name": "Tebukuro — Japanese female"},
    {"id": "kokoro-jm-kumo",     "language": "ja",    "display_name": "Kumo — Japanese male"},
