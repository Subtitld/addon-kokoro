    {"id": "kokoro-zf-xiaoni",   "language": "zh-cn", "display_name": "Xiaoni — Chinese female"},
    {"id": "kokoro-zf-xiaoxiao", "language": "zh-cn", "display_name": "Xiaoxiao — Chinese female"},
    {"id": "kokoro-zf-xiaoyi",   "language": "zh-cn", "display_name": "Xiaoyi — Chinese female"},
    {"id": "kokoro-zm-yunjian",  "language": "zh-cn", "display_name": "Yunjian — Chinese male"},
    {"id": "kokoro-zm-yunxi",    "language": "zh-cn", "display_name": "Yunxi — Chinese male"},
    {"id": "kokoro-zm-yunxia",   "language": "zh-cn", "display_name": "Yunxia — Chinese male"},
    {"id": "kokoro-zm-yunyang",  "language": "zh-cn", "display_name": "Yunyang — Chinese male"},
    {"id": "kokoro-ef-dora",     "language": "es",    "display_name": "Dora — Spanish female"},
    {"id": "kokoro-em-alex",     "language": "es",    "display_name": "Alex — Spanish male"},
    {"id": "kokoro-em-santa",    "language": "es",    "display_name": "Santa — Spanish male"},
    {"id": "kokoro-ff-siwis",    "language": "fr",    "display_name": "Siwis — French female"},
    {"id": "kokoro-hf-alpha",    "language": "hi",    "display_name": "Alpha — Hindi female"},
    {"id": "kokoro-hf-beta",     "language": "hi",    "display_name": "Beta — Hindi female"},
    {"id": "kokoro-hm-omega",    "language": "hi",    "display_name": "Omega — Hindi male"},
    {"id": "kokoro-hm-psi",      "language": "hi",    "display_name": "Psi — Hindi male"},
    {"id": "kokoro-if-sara",     "language": "it",    "display_name": "Sara — Italian female"},
    {"id": "kokoro-im-nicola",   "language": "it",    "display_name": "Nicola — Italian male"},
    {"id": "kokoro-pf-dora",     "language": "pt-br", "display_name": "Dora — Brazilian Portuguese female"},
    {"id": "kokoro-pm-alex",     "language": "pt-br", "display_name": "Alex — Brazilian Portuguese male"},
    {"id": "kokoro-pm-santa",    "language": "pt-br", "display_name": "Santa — Brazilian Portuguese male"}
  ],
  "models": [
    {"id": "kokoro-82m", "repo": "hexgrad/Kokoro-82M", "size_mb": 82, "bundled": false}
  ],
  "disk_required_mb": 256,
  "ram_required_mb": 1024,
  "gpu": "optional",
  "config_schema": {
    "fields": [
      {
        "key": "device",
        "type": "select",
        "label": "Inference device",
        "default": "cpu",
        "options": [
          {"value": "cpu",  "label": "CPU (fast — Kokoro is small)"},
          {"value": "cuda", "label": "CUDA (NVIDIA GPU, fastest)"},
          {"value": "mps",  "label": "MPS (Apple Silicon)"}
        ]
      },
      {
        "key": "speed",
        "type": "number",
        "label": "Speech speed multiplier (1.0 = normal)",
        "default": 1.0,
        "min": 0.5,
        "max": 2.0,
        "step": 0.05
      }
    ]
  }
}
