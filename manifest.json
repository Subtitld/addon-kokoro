{
  "manifest_version": 1,
  "id": "kokoro",
  "version": "1.0.5",
  "display_name": "Kokoro 82M (offline)",
  "summary": "Lightweight Apache-2.0 neural TTS. ~80 MB model, 9 languages, 54 preset voices, no cloning.",
  "author": "Subtitld add-on team",
  "license": "Apache-2.0 (wrapper) + Apache-2.0 (Kokoro 82M weights)",
  "executable": "bin/kokoro-addon",
  "protocol": 1,
  "startup_timeout_sec": 60,
  "platforms": ["linux", "macos", "windows"],
  "tasks": ["tts.synthesize"],
  "voice_clone": false,
  "languages": ["en-us", "en-gb", "es", "fr", "hi", "it", "ja", "pt-br", "zh-cn"],
  "voices": [
    {"id": "kokoro-af-heart",    "language": "en-us", "display_name": "Heart — American female (default)"},
    {"id": "kokoro-af-alloy",    "language": "en-us", "display_name": "Alloy — American female"},
